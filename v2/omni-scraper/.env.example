# ═══════════════════════════════════════════════════
#  OMNI-SCRAPER — Environment Configuration
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── LLM Provider (choose one: openai | claude | kimi | qwen) ──
LLM_PROVIDER=claude

# ── OpenAI ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic Claude ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenRouter — used by BOTH Kimi K2.5 AND Qwen ───
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
KIMI_MODEL=moonshotai/kimi-k2.5
QWEN_MODEL=qwen/qwen3.5-397b-a17b

NVIDIA_API_KEY=nvapi-


# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=omni_memory

# ── API Server ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Proxy (optional) ────────────────────────────────
PROXY_ENABLED=false
PROXY_LIST_PATH=config/proxies.txt

# ── Scraper Defaults ────────────────────────────────
DEFAULT_CONCURRENCY=5
DEFAULT_DELAY_MS=1500
MAX_RETRIES=3
SESSION_TTL_HOURS=168

# ── Telemetry ───────────────────────────────────────
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
