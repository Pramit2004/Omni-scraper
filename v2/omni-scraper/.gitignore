# ═══════════════════════════════
#  OMNI-SCRAPER .gitignore
# ═══════════════════════════════

# Environment
.env
.env.*
!.env.example
*.env


# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
.venv/
env/
.tox/

# Playwright
playwright-report/
test-results/

# Data & Sessions
data/
sessions/
identities/
exports/
*.csv
*.tsv
*.json
!config/*.json
!package*.json

# DB
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log
structlog/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Node (frontend)
node_modules/
frontend/dist/
frontend/build/
frontend/.next/

# Docker
.docker/

# Telemetry
prometheus_data/
grafana_data/

# Secrets
*.pem
*.key
*.cert
proxies.txt
proxy_list.txt
